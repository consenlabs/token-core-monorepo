# Optional: one Alchemy key for any chains.
# Apply here: https://dashboard.alchemy.com/apps
VITE_ALCHEMY_API_KEY=

# Optional: Etherscan V2 key for Sepolia + Base Sepolia contract source/ABI lookup.
# Apply here: https://etherscan.io/apidashboard
VITE_ETHERSCAN_API_KEY=

# Required for CLI policy simulation accuracy and richer asset-change display in Web UI.
# Apply here: https://dashboard.tenderly.co/<ACCOUNT_SLUG>/<PROJECT_SLUG>/nodes
VITE_TENDERLY_NODE_ACCESS_KEY=

# Optional: for public shareable simulation links (all three must be set together).
# Apply here: https://dashboard.tenderly.co/<ACCOUNT_SLUG>/<PROJECT_SLUG>/settings
VITE_TENDERLY_ACCOUNT_SLUG=
VITE_TENDERLY_PROJECT_SLUG=
VITE_TENDERLY_ACCESS_TOKEN=

# Optional: CLI wallet storage root. Defaults to ~/.tokencore-cli
TOKENCORE_CLI_HOME="./.tokencore-cli"

# Optional: CLI password for non-interactive scripts. Prefer setting in shell env,
# CI secret, or a secure secret manager instead of storing long-term in files.
TOKENCORE_CLI_PASSWORD=

# AI summary (Traditional Chinese). Providers are tried in order:
#   Gemini → Groq → local rule-based fallback (always available, no key needed).
# Warning: VITE_* vars are exposed to the browser bundle. Use demo/dev keys only.

# Recommended first choice — free tier (1500 RPD, gemini-2.0-flash).
# Tip: create a NEW Google Cloud Project for a fresh daily quota.
# Apply here: https://aistudio.google.com/api-keys
VITE_GEMINI_API_KEY=

# Recommended second choice — most generous free tier (1000 RPD for llama-3.3-70b,
# or switch model to llama-3.1-8b-instant for 14400 RPD at slightly lower quality).
# Backed by Meta's open-source Llama models; OpenAI-compatible API.
# Free account, no credit card needed. Apply here: https://console.groq.com/keys
VITE_GROQ_API_KEY=
