{
  "name": "tokencore-cli",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "typecheck": "tsc -b",
    "build:ui": "vite build",
    "build": "npm run typecheck && npm run build:ui",
    "cli": "tsx src/cli.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:unit": "vitest run --exclude \"src/test/cli/**\"",
    "test:cli": "vitest run \"src/test/cli/cli-policy-gating.test.ts\"",
    "test:smoke:chains": "vitest run src/test/lib/chain-compatibility-smoke.test.ts",
    "test:ui": "vitest run \"src/test/ui/**/*.test.{ts,tsx}\" --passWithNoTests",
    "test": "npm run test:unit && npm run test:cli",
    "verify": "npm run lint && npm run typecheck && npm run test:unit && npm run test:cli && npm run test:smoke:chains && npm run build:ui",
    "audit:high": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@consenlabs/tcx-wasm": "^0.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "viem": "^2.47.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.3"
  }
}
